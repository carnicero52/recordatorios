generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Configuración del sistema
model Configuracion {
  id                String   @id @default(cuid())
  nombreSistema     String   @default("Sistema de Recordatorios")

  // Gmail SMTP
  gmailEmail        String?
  gmailPassword     String?
  gmailActivo       Boolean  @default(false)

  // Telegram Bot
  telegramBotToken  String?
  telegramActivo    Boolean  @default(false)

  // Twilio SMS
  twilioAccountSid  String?
  twilioAuthToken   String?
  twilioPhoneNumber String?
  smsActivo         Boolean  @default(false)

  // Horario de ejecución
  horaEjecucion     String   @default("09:00")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Recordatorios
model Recordatorio {
  id                String   @id @default(cuid())

  nombre            String
  correo            String
  fechaRecordatorio DateTime
  asunto            String
  mensaje           String

  telegramId        String?
  numeroTelefono    String?

  estado            String   @default("pendiente")
  ultimoIntento     DateTime?
  errorMensaje      String?

  enviarEmail       Boolean  @default(true)
  enviarTelegram    Boolean  @default(false)
  enviarSMS         Boolean  @default(false)

  repetir           Boolean  @default(false)
  frecuencia        String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  envios            Envio[]
}

// Historial de envíos
model Envio {
  id              String   @id @default(cuid())
  recordatorioId  String
  recordatorio    Recordatorio @relation(fields: [recordatorioId], references: [id], onDelete: Cascade)
  canal           String
  destinatario    String
  estado          String
  error           String?
  enviadoAt       DateTime @default(now())
}

// Administradores
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  nombre    String
  rol       String   @default("admin")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
}
