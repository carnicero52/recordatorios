generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Configuracion {
  id                String   @id @default(cuid())
  nombreSistema     String   @default("Sistema de Recordatorios Multicanal")

  // Gmail SMTP
  gmailEmail        String?
  gmailPassword     String?
  gmailActivo       Boolean  @default(false)

  // Telegram Bot
  telegramBotToken  String?
  telegramActivo    Boolean  @default(false)

  // SMS (Twilio)
  twilioAccountSid  String?
  twilioAuthToken   String?
  twilioPhoneNumber String?
  smsActivo         Boolean  @default(false)

  // Horario
  horaEjecucion     String   @default("09:00")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Recordatorio {
  id                String   @id @default(cuid())
  nombre            String
  correo            String
  fechaRecordatorio DateTime
  asunto            String
  mensaje           String
  telegramId        String?
  numeroTelefono    String?
  estado            String   @default("pendiente")
  ultimoIntento     DateTime?
  errorMensaje      String?
  enviarEmail       Boolean  @default(true)
  enviarTelegram    Boolean  @default(false)
  enviarSMS         Boolean  @default(false)
  repetir           Boolean  @default(false)
  frecuencia        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  envios            Envio[]
}

model Envio {
  id              String   @id @default(cuid())
  recordatorioId  String
  recordatorio    Recordatorio @relation(fields: [recordatorioId], references: [id], onDelete: Cascade)
  canal           String
  destinatario    String
  estado          String
  error           String?
  enviadoAt       DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  nombre    String
  rol       String   @default("admin")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
}
